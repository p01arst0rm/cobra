// Stylus theme for nuxt page content
// ---------------------------------------------------------

@import 'assets/fonts/Nautilus/Nautilus.styl'

#page {

	p {
		color: #202020;
		font-family: Nautilus, Helvetica, sans-serif;
	}

	a {
		font-weight: bold;
	}

	b {
		font-weight: bold;
	}

	ul {
		font-family: Nautilus;
		font-size: 1.5rem;
		margin-left: .25rem;
	}

	li {
		display: list-item;
		padding: .1rem .2rem;
	}

	br {
		clear: both;
	}

}
